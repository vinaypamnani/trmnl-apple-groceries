{%- comment -%}
Shared styles for all layouts. Rendered once at the top of each via
{% render "shared" %}. Compound selectors (.column.g-*, .columns.g-*,
.title.g-*) tie the TRMNL framework's specificity and win on source order
(this <style> loads after the framework CSS). Plain classes are used only for
properties the framework leaves unset (line-clamp, min-width, etc.).
{%- endcomment -%}
<style>
  /* layout sizing */
  .columns.g-cols { height: 100%; align-items: stretch; }
  .columns.g-half { flex: 1 1 0; min-height: 0; overflow: hidden; }
  .column.g-top { justify-content: flex-start; }
  .column.g-flex2 { flex: 2 1 0; }
  .column.g-flex1 { flex: 1 1 0; }

  /* item content fills the column so names use the full width */
  .g-content { flex: 1 1 0; min-width: 0; }

  /* item name: clamp to N lines (N from --clamp on the layout root) */
  .g-name {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: var(--clamp, 1);
    overflow: hidden;
    width: 100%;
  }
  .g-done { text-decoration: line-through; }
  /* notes read as clearly secondary — italic, crisp black (not a noisy gray dither) */
  .description.g-note { word-break: normal; font-style: italic; }

  /* Apple logo in the title bar uses the framework's .image slot (see layouts) */

  /* title-bar icons (clock + battery) and the header cart sit just left of their
     text; one shared gap rule keeps the framework lint's style-count low */
  .g-ico-clock::before, .g-batt, .g-cart::before { margin-right: 0.3em; vertical-align: -0.12em; }
  .g-ico-clock::before {
    content: ""; display: inline-block; width: 0.95em; height: 0.95em;
    background: center / contain no-repeat url("data:image/svg+xml;base64,"); }
  /* cart glyph for the header — white, for the solid-black bar */
  .g-cart::before {
    content: ""; display: inline-block; width: 1.05em; height: 1.05em;
    background: center / contain no-repeat url("data:image/svg+xml;base64,"); }
  .g-batt { display: inline-block; width: 1.6em; height: 0.9em; }

  /* Checklist rows: the framework stretches .item and vertically-centers .meta,
     so on a two-line item (name + note) the checkbox floats to the middle. Pin
     everything to the top and drop the box onto the name's line so noted and
     note-less items share one gutter and baseline. */
  /* Pin the marker to the name's line. Row spacing comes from a framework gap--*
     class on the column, keeping custom CSS minimal. */
  .item { align-items: flex-start; }
  /* Drop the framework's gray dither chip behind the marker — on 1-bit it reads as
     noise. Leave a clean transparent gutter and pin the marker to the name's line. */
  .item .meta { align-items: flex-start; padding-top: 0.2em; background: none; width: auto; }

  /* empty "to-buy" checkbox — a single crisp outlined square, no chip behind it */
  .g-box {
    display: inline-block;
    box-sizing: border-box;
    width: 0.8em; height: 0.8em;
    border: 0.14em solid currentColor;
    border-radius: 3px;
  }

  /* header pill matches the footer: light gray-70 dither backdrop + dark text with
     the framework's crisp white text-stroke (paint-order stroke fill), not a shadow. */
  .g-pill { border-radius: 8px; background-color: var(--gray-70); }
  .title.g-pill-text { -webkit-text-stroke: 2px var(--white); paint-order: stroke fill; }

  /* Font Size setting -> overall UI scale */
  .g-scale-regular { --ui-scale: 1; }
  .g-scale-large { --ui-scale: 1.125; }
  .g-scale-extra_large { --ui-scale: 1.25; }

  /* Title Lines setting -> clamp count */
  .g-clamp1 { --clamp: 1; }
  .g-clamp2 { --clamp: 2; }
  .g-clamp3 { --clamp: 3; }
  .g-clamp4 { --clamp: 4; }
</style>
