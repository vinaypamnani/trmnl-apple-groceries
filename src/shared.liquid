{%- comment -%}
Shared setup + styles for all layouts. trmnlp auto-prepends this file to each
layout — do NOT add {% raw %}{% render "shared" %}{% endraw %}, that double-renders.
Because it's prepended inline (not a `render`), the variables assigned in the
{% raw %}{% liquid %}{% endraw %} block below are in scope for every layout body,
so the source-detection + title-bar setup lives here once instead of in all four.
Compound selectors (.column.g-*, .columns.g-*, .description.g-*) tie the TRMNL
framework's specificity and win on source order (this <style> loads after the
framework CSS). Plain classes are used only for the few properties no framework
utility covers well (line-clamp, min-width:0, italic, line-through, checkbox).
{%- endcomment -%}
{% liquid
assign font_size = trmnl.plugin_settings.custom_fields_values.font_size | default: "large"

# The VIEW follows the data shape, not the setting: a `completed` array or
# `n`-keyed items means the Shortcut payload, which adds the Completed column.
# `source_label` names the detected source ("TRMNL Companion" / "Apple Shortcuts")
# — the footnote always shows it as "Data provided by …". The List Source setting
# (`list_source`) doesn't affect rendering; it only tailors the form (settings.yml).
assign use_shortcut = false
if completed or reminders.first.t
assign use_shortcut = true
endif
assign source_label = "TRMNL Companion"
if use_shortcut
assign source_label = "Apple Shortcuts"
endif

assign pending_items = reminders
if use_shortcut
assign show_completed = true
assign header_title = "Pending"
else
assign show_completed = false
assign pending_label = reminders.first.list_name | default: "Groceries"
# Companion only: a custom Top Title overrides the list name.
assign header_title = trmnl.plugin_settings.custom_fields_values.title_top | default: pending_label
endif

# Title-bar right label: Date & Time / Battery / both / Custom text / Blank.
# Date & time is rendered in the device's local wall-clock (UTC + the user's offset).
assign rt_dt = trmnl.system.timestamp_utc | plus: trmnl.user.utc_offset | date: "%b %-d, %-I:%M %p"
assign batt_pct = trmnl.device.percent_charged | round
assign batt_fill = batt_pct | times: 16 | divided_by: 100
assign show_dt = false
assign show_batt = false
assign custom_text = ""
case trmnl.plugin_settings.custom_fields_values.title_bottom_right
when "date_and_time"
assign show_dt = true
when "battery"
assign show_batt = true
when "date_time_and_battery"
assign show_dt = true
assign show_batt = true
when "custom"
assign custom_text = trmnl.plugin_settings.custom_fields_values.title_bottom_right_custom
when "blank"
assign show_dt = false
else
assign show_dt = true
endcase

# Inline-SVG glyphs, defined once and reused by every layout. They use
# stroke/fill "currentColor" so they follow the framework text colour and flip in
# dark mode automatically (the same trick as the battery <svg>) — and being real
# inline SVG, not CSS masks, they render through TRMNL's engine. The header glyphs
# hold only the inner paths, so each layout sizes its own wrapping <svg> (cart's
# path carries its heavier stroke; the wrapper's stroke-width is the bag default).
assign cart_glyph = '<path d="M1 2h3.5l2.3 12.2a1.6 1.6 0 0 0 1.6 1.3h9.1a1.6 1.6 0 0 0 1.6-1.3L21.5 7H6" stroke-width="2.2"/><circle cx="9.5" cy="20" r="1.7" fill="currentColor" stroke="none"/><circle cx="18.5" cy="20" r="1.7" fill="currentColor" stroke="none"/>'
assign bag_glyph = '<path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>'
assign clock_svg = '<svg class="g-tbico" width="0.95em" height="0.95em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6 V12 H17"/></svg>'
%}
<style>
  /* layout sizing — g-cols grows to fill so the footnote can sit below it */
  /* layout sizing — the content area grows to fill so the footnote sits below it,
     and (crucially) gives each list column a BOUNDED height so the framework's
     overflow system (data-overflow-*, "and N more") can detect overflow. The 2:1
     Pending:Completed ratio comes from g-flex2 on Pending; Completed keeps the
     framework default `flex: 1`. Grid `col--span` can't combine fixed spans with
     the height-bounded columns the overflow engine needs. */
  .columns.g-cols { flex: 1 1 0; min-height: 0; align-items: stretch; }
  /* .g-half: framework .columns already sets overflow:hidden, so we only add the
     grow + min-height:0 the overflow engine needs. */
  .columns.g-half { flex: 1 1 0; min-height: 0; }
  /* min-height:0 lets these flex columns shrink below their content height (flex
     items default to min-height:auto and won't). Without it the column expands to
     fit all items, so the overflow engine reads the full content height as its
     budget and never hides items / shows "and N more". */
  .column.g-top { justify-content: flex-start; min-height: 0; }
  .column.g-flex2 { flex: 2 1 0; }

  /* item content fills the column so names use the full width */
  .g-content { flex: 1 1 0; min-width: 0; }

  /* item name: a grocery item is one line — truncate the rest. CSS line-clamp, NOT
     the framework Clamp engine (data-clamp): that measures the narrow overflow
     sub-columns too conservatively and cuts names off early. width:100% makes the
     box fill the column so it only truncates at the real edge. */
  .g-name {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
    overflow: hidden;
    width: 100%;
  }
  .g-done { text-decoration: line-through; }
  /* shared italic: item notes read as secondary (crisp black, not a noisy gray
     dither) and the "Data provided by …" footnote. No framework rule sets
     font-style on .description, so a plain class wins without a compound selector. */
  .g-italic { font-style: italic; }

  /* Apple logo in the title bar uses the framework's .image slot (see layouts) */

  /* title-bar glyphs (clock, battery) are inline <svg>s using currentColor, so they
     adapt to dark mode along with the text. This only sets their shared inline
     alignment + spacing — each <svg> carries its own width/height. */
  .g-tbico { display: inline-block; vertical-align: -0.15em; margin-right: 0.25em; }

  /* Checklist rows: the framework stretches .item and vertically-centers .meta,
     so on a two-line item (name + note) the checkbox floats to the middle. Pin
     everything to the top and drop the box onto the name's line so noted and
     note-less items share one gutter and baseline. */
  /* Pin the marker to the name's line. Row spacing comes from a framework gap--*
     class on the column, keeping custom CSS minimal. */
  .item { align-items: flex-start; }
  /* Drop the framework's gray dither chip behind the marker — on 1-bit it reads as
     noise. Leave a clean transparent gutter and pin the marker to the name's line. */
  .item .meta { align-items: flex-start; padding-top: 0.2em; background: none; width: auto; }

  /* empty "to-buy" checkbox — a single crisp outlined square, no chip behind it */
  .g-box {
    display: inline-block;
    box-sizing: border-box;
    width: 0.8em; height: 0.8em;
    border: 0.14em solid currentColor;
    border-radius: 3px;
  }
  /* checked-off item: filled box + tick. Light = black box/white tick; dark mode
     swaps to white box/black tick so it stays the inverse of the empty box. */
  .g-check {
    display: inline-block;
    width: 0.8em; height: 0.8em;
    background: center / contain no-repeat url("data:image/svg+xml;base64,");
  }
  .screen--dark-mode .g-check {
    background: center / contain no-repeat url("data:image/svg+xml;base64,");
  }

  /* Font Size setting -> overall UI scale */
  .g-scale-regular { --ui-scale: 1; }
  .g-scale-large { --ui-scale: 1.125; }
  .g-scale-extra_large { --ui-scale: 1.25; }
</style>
