{%- comment -%}
Shared setup + styles for all layouts. trmnlp auto-prepends this file to each
layout — do NOT add {% raw %}{% render "shared" %}{% endraw %}, that double-renders.
Because it's prepended inline (not a `render`), the variables assigned in the
{% raw %}{% liquid %}{% endraw %} block below are in scope for every layout body,
so the source-detection + title-bar setup lives here once instead of in all four.
Compound selectors (.column.g-*, .columns.g-*, .title.g-*) tie the TRMNL
framework's specificity and win on source order (this <style> loads after the
framework CSS). Plain classes are used only for properties the framework leaves
unset (line-clamp, min-width, etc.).
{%- endcomment -%}
{% liquid
assign font_size = trmnl.plugin_settings.custom_fields_values.font_size | default: "large"

# Both payloads carry the to-buy list in `reminders`. The Shortcut also sends a
# `completed` array (with short `n`/`o` item keys), which adds the Completed column.
# List Source: "shortcut"/"companion" force a view; "auto" (default) detects from
# the payload — Completed column when `completed` or `n`-keyed items are present.
assign source = trmnl.plugin_settings.custom_fields_values.list_source | default: "auto"
assign use_shortcut = false
if source == "shortcut"
assign use_shortcut = true
elsif source == "auto"
if completed or reminders.first.n
assign use_shortcut = true
endif
endif

assign pending_items = reminders
if use_shortcut
assign show_completed = true
assign pending_label = "Pending"
assign header_title = pending_label
else
assign show_completed = false
assign pending_label = reminders.first.list_name | default: "Groceries"
# Companion only: a custom Top Title overrides the list name.
assign header_title = trmnl.plugin_settings.custom_fields_values.title_top | default: pending_label
endif

# Title-bar right label: Date & Time / Battery / both / Custom text / Blank.
# Date & time is rendered in the device's local wall-clock (UTC + the user's offset).
assign rt_dt = trmnl.system.timestamp_utc | plus: trmnl.user.utc_offset | date: "%b %-d, %-I:%M %p"
assign batt_pct = trmnl.device.percent_charged | round
assign batt_fill = batt_pct | times: 16 | divided_by: 100
assign show_dt = false
assign show_batt = false
assign custom_text = ""
case trmnl.plugin_settings.custom_fields_values.title_bottom_right
when "date_and_time"
assign show_dt = true
when "battery"
assign show_batt = true
when "date_time_and_battery"
assign show_dt = true
assign show_batt = true
when "custom"
assign custom_text = trmnl.plugin_settings.custom_fields_values.title_bottom_right_custom
when "blank"
assign show_dt = false
else
assign show_dt = true
endcase
%}
<style>
  /* layout sizing */
  .columns.g-cols { height: 100%; align-items: stretch; }
  .columns.g-half { flex: 1 1 0; min-height: 0; overflow: hidden; }
  .column.g-top { justify-content: flex-start; }
  .column.g-flex2 { flex: 2 1 0; }
  .column.g-flex1 { flex: 1 1 0; }

  /* item content fills the column so names use the full width */
  .g-content { flex: 1 1 0; min-width: 0; }

  /* item name: a grocery item is one line — truncate the rest */
  .g-name {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
    overflow: hidden;
    width: 100%;
  }
  .g-done { text-decoration: line-through; }
  /* notes read as clearly secondary — italic, crisp black (not a noisy gray dither) */
  .description.g-note { word-break: normal; font-style: italic; }

  /* Apple logo in the title bar uses the framework's .image slot (see layouts) */

  /* title-bar / header glyphs (clock, cart, bag) are MASKS filled with the
     framework text colour, so they flip black->white in dark mode like the rest of
     the UI. The battery is an inline <svg> using currentColor (adapts the same way).
     One shared gap rule keeps the framework lint's style-count low. */
  .g-ico-clock::before, .g-batt, .g-cart::before, .g-bag::before { margin-right: 0.3em; vertical-align: -0.12em; }
  .g-ico-clock::before, .g-cart::before, .g-bag::before {
    content: ""; display: inline-block; background: var(--framework-text-primary);
    -webkit-mask: center / contain no-repeat var(--g-icon);
    mask: center / contain no-repeat var(--g-icon);
  }
  .g-ico-clock::before { width: 0.95em; height: 0.95em; --g-icon: url("data:image/svg+xml;base64,"); }
  .g-cart::before { width: 1.05em; height: 1.05em; --g-icon: url("data:image/svg+xml;base64,"); }
  .g-bag::before { width: 1.05em; height: 1.05em; --g-icon: url("data:image/svg+xml;base64,"); }
  .g-batt { display: inline-block; width: 1.6em; height: 0.9em; }

  /* Checklist rows: the framework stretches .item and vertically-centers .meta,
     so on a two-line item (name + note) the checkbox floats to the middle. Pin
     everything to the top and drop the box onto the name's line so noted and
     note-less items share one gutter and baseline. */
  /* Pin the marker to the name's line. Row spacing comes from a framework gap--*
     class on the column, keeping custom CSS minimal. */
  .item { align-items: flex-start; }
  /* Drop the framework's gray dither chip behind the marker — on 1-bit it reads as
     noise. Leave a clean transparent gutter and pin the marker to the name's line. */
  .item .meta { align-items: flex-start; padding-top: 0.2em; background: none; width: auto; }

  /* empty "to-buy" checkbox — a single crisp outlined square, no chip behind it */
  .g-box {
    display: inline-block;
    box-sizing: border-box;
    width: 0.8em; height: 0.8em;
    border: 0.14em solid var(--framework-text-primary);
    border-radius: 3px;
  }
  /* checked-off item: filled box + tick. Light = black box/white tick; dark mode
     swaps to white box/black tick so it stays the inverse of the empty box. */
  .g-check {
    display: inline-block;
    width: 0.8em; height: 0.8em;
    background: center / contain no-repeat url("data:image/svg+xml;base64,");
  }
  .screen--dark-mode .g-check {
    background: center / contain no-repeat url("data:image/svg+xml;base64,");
  }

  /* header pill mirrors the footer (.title_bar) using the SAME framework vars, so it
     adapts to dark/light identically: the gray-70 dither backdrop and the contrast-
     aware text-stroke (paint-order stroke fill) both flip with the theme. */
  .g-pill { border-radius: 8px; background: var(--bg-gray-70-color, transparent) var(--bg-gray-70-image, none) repeat center / var(--dither-bg-size, auto); }
  .title.g-pill-text { -webkit-text-stroke: 2px var(--framework-stroke-contrast); paint-order: stroke fill; }

  /* Font Size setting -> overall UI scale */
  .g-scale-regular { --ui-scale: 1; }
  .g-scale-large { --ui-scale: 1.125; }
  .g-scale-extra_large { --ui-scale: 1.25; }
</style>
