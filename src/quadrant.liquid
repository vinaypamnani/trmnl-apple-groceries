{% liquid
assign font_size = trmnl.plugin_settings.custom_fields_values.font_size | default: "large"

case trmnl.plugin_settings.custom_fields_values.show_flags
when "no"
assign show_flags = false
else
assign show_flags = true
endcase

# Prefer the Shortcut (pending/completed); fall back to Companion reminders.
if pending or completed
assign pending_items = pending
assign show_completed = true
assign pending_label = "Pending"
else
assign pending_items = reminders
assign show_completed = false
assign pending_label = reminders.first.list_name | default: "Groceries"
endif
%}

<div class="layout layout--col layout--top g-scale-{{ font_size }}">
  <div class="columns g-cols">
    <div class="column g-top" data-list-limit="true" data-list-hidden-count="true">
      <div class="bg--backdrop p--1 text--center g-pill">
        <span class="title title--small text--white g-pill-text">{{ pending_label }} · {{ pending_items | size }}</span>
      </div>
      {% if pending_items == empty %}
      <span class="description">All shopped!</span>
      {% else %}
      {% for item in pending_items %}
      {% assign name = item.title | default: item.n %}
      {% assign flagged = false %}
      {% if show_flags and item.f %}{% assign flagged = true %}{% endif %}
      <div class="item">
        <div class="meta">{% if flagged %}<span class="index">⚑</span>{% else %}<span class="g-box"></span>{% endif %}</div>
        <div class="content g-content">
          <span class="title title--small g-name{% if flagged %} g-flagged{% endif %}">{{ name }}</span>
        </div>
      </div>
      {% endfor %}
      {% endif %}
    </div>
  </div>
</div>

<div class="title_bar">
  <span class="title">🛒 {{ trmnl.plugin_settings.instance_name }}</span>
  {% if show_completed %}
  <span class="instance">✓ {{ completed | size }} done</span>
  {% else %}
  <span class="instance">{{ pending_items | size }} to buy</span>
  {% endif %}
</div>
