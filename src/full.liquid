{% liquid
assign title_lines = trmnl.plugin_settings.custom_fields_values.title_lines | default: 1
assign font_size = trmnl.plugin_settings.custom_fields_values.font_size | default: "large"

# Prefer the Shortcut (pending/completed is the superset); fall back to the
# Companion app's reminders (pending-only) when neither is sent.
if pending or completed
assign pending_items = pending
assign show_completed = true
assign pending_label = "Pending"
else
assign pending_items = reminders
assign show_completed = false
assign pending_label = reminders.first.list_name | default: "Groceries"
endif

# Title-bar right label: Date & Time / Battery / both / Custom text / Blank.
# Date & time is rendered in the device's local wall-clock (UTC + the user's offset).
assign rt_dt = trmnl.system.timestamp_utc | plus: trmnl.user.utc_offset | date: "%b %-d, %-I:%M %p"
assign batt_pct = trmnl.device.percent_charged | round
assign batt_fill = batt_pct | times: 16 | divided_by: 100
assign show_dt = false
assign show_batt = false
assign custom_text = ""
case trmnl.plugin_settings.custom_fields_values.right_label
when "battery"
assign show_batt = true
when "date_time_and_battery"
assign show_dt = true
assign show_batt = true
when "custom"
assign custom_text = trmnl.plugin_settings.custom_fields_values.custom_label
when "blank"
assign show_dt = false
else
assign show_dt = true
endcase
%}

<div class="layout layout--row layout--top g-scale-{{ font_size }} g-clamp{{ title_lines }}">
  <div class="columns gap--medium g-cols">

    <div class="column g-top {% if show_completed %}g-flex2{% else %}g-flex1{% endif %}">
      <div class="bg--backdrop p--1 text--center g-pill">
        <span class="title text--white g-pill-text">{{ pending_label }} · {{ pending_items | size }}</span>
      </div>
      {% if pending_items == empty %}
      <div class="flex flex--col h--56 lg:h--80 gap--space-between text--center">
        <span class="title lg:title--large">All shopped!</span>
        <span class="description lg:description--large">Nothing left to buy.</span>
      </div>
      {% else %}
      <div class="columns gap--large" data-overflow-max-cols="2" data-overflow-counter="true">
        <div class="column">
          {% for item in pending_items %}
          {% assign name = item.title | default: item.n %}
          {% assign note = item.notes | default: item.o %}
          <div class="item">
            <div class="meta">
              <span class="g-box"></span>
            </div>
            <div class="content g-content">
              <span class="title title--small g-name">{{ name }}</span>
              {% if note != blank %}
              <span class="description g-note">{{ note }}</span>
              {% endif %}
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
      {% endif %}
    </div>

    {% if show_completed %}
    <div class="column g-top g-flex1" data-list-limit="true" data-list-hidden-count="true">
      <div class="bg--backdrop p--1 text--center g-pill">
        <span class="title text--white g-pill-text">Completed · {{ completed | size }}</span>
      </div>
      {% if completed == empty %}
      <span class="description">Nothing in cart yet.</span>
      {% else %}
      {% for item in completed %}
      <div class="item">
        <div class="meta"><span class="index">✓</span></div>
        <div class="content g-content">
          <span class="title title--small text--muted g-done g-name">{{ item.n }}</span>
        </div>
      </div>
      {% endfor %}
      {% endif %}
    </div>
    {% endif %}

  </div>
</div>

<div class="title_bar">
  <img class="image" src="data:image/png;base64,">
  <span class="title">{{ trmnl.plugin_settings.instance_name }}</span>
  {% if show_dt or show_batt or custom_text != blank %}
  <span class="instance">{% if show_dt %}<span class="g-ico-clock"></span>{{ rt_dt }}{% endif %}{% if show_dt and show_batt %} · {% endif %}{% if show_batt %}<svg class="g-batt" viewBox="0 0 28 16"><rect x="1" y="2" width="22" height="12" rx="2" fill="none" stroke="currentColor" stroke-width="2"/><rect x="24" y="5" width="3" height="6" rx="1" fill="currentColor"/><rect x="4" y="5" width="{{ batt_fill }}" height="6" fill="currentColor"/></svg>{{ batt_pct }}%{% endif %}{{ custom_text }}</span>
  {% endif %}
</div>
