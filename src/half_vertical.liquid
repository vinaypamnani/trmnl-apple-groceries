<div class="layout layout--col layout--top gap--medium g-scale-{{ font_size }}">

  <div class="columns g-half">
    <div class="column g-top">
      <div class="flex flex--row flex--center-x flex--center-y gap--small p--1 bg--gray-70 rounded">
        {% assign pc = pending_items | size %}
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">{{ cart_glyph }}</svg>
        <span class="title title--small">{{ header_title }} · {{ pc }} item{% if pc != 1 %}s{% endif %}</span>
      </div>
      {% if pending_items == empty %}
      <span class="description">All shopped!</span>
      {% else %}
      <div class="columns" data-overflow-max-cols="1" data-overflow-max-cols-lg="2" data-overflow-counter="true">
        <div class="column">
          {% for item in pending_items %}
          {% assign name = item.title | default: item.t %}
          {% assign note = item.notes | default: item.n %}
          <div class="item">
            <div class="meta">
              <span class="g-box"></span>
            </div>
            <div class="content g-content">
              <span class="title title--small lg:title--base g-name">{{ name }}</span>
              {% if note != blank %}
              <span class="description g-italic">{{ note }}</span>
              {% endif %}
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
      {% endif %}
    </div>
  </div>

  {% if show_completed %}
  <div class="columns g-half">
    <div class="column g-top">
      <div class="flex flex--row flex--center-x flex--center-y gap--small p--1 bg--gray-70 rounded">
        {% assign cc = completed | size %}
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">{{ bag_glyph }}</svg>
        <span class="title title--small">Completed · {{ cc }} item{% if cc != 1 %}s{% endif %}</span>
      </div>
      {% if completed == empty %}
      <span class="description">Nothing in cart yet.</span>
      {% else %}
      <div class="columns" data-overflow-max-cols="1" data-overflow-max-cols-lg="2" data-overflow-counter="true">
        <div class="column">
          {% for item in completed %}
          <div class="item">
            <div class="meta"><span class="g-check"></span></div>
            <div class="content g-content">
              <span class="title title--small lg:title--base text--muted g-done g-name">{{ item.title | default: item.t }}</span>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
      {% endif %}
    </div>
  </div>
  {% endif %}

  <div class="description text--center p--1 g-italic">Data provided by {{ source_label }}</div>
</div>

<div class="title_bar">
  <img class="image" src="data:image/png;base64,">
  <span class="title">{{ trmnl.plugin_settings.instance_name }}</span>
  {% if show_dt or show_batt or custom_text != blank %}
  <span class="instance">{% if show_dt %}{{ clock_svg }}{{ rt_dt }}{% endif %}{% if show_dt and show_batt %} · {% endif %}{% if show_batt %}<svg class="g-tbico" width="1.6em" height="0.9em" viewBox="0 0 28 16"><rect x="1" y="2" width="22" height="12" rx="2" fill="none" stroke="currentColor" stroke-width="2"/><rect x="24" y="5" width="3" height="6" rx="1" fill="currentColor"/><rect x="4" y="5" width="{{ batt_fill }}" height="6" fill="currentColor"/></svg>{{ batt_pct }}%{% endif %}{{ custom_text }}</span>
  {% endif %}
</div>
